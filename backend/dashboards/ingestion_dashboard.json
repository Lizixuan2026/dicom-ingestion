{
  "dashboard": {
    "id": null,
    "title": "DICOM Ingestion - Production Overview",
    "tags": ["dicom", "ingestion", "production"],
    "timezone": "UTC",
    "schemaVersion": 36,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Ingestion Rate (items/min)",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(dicom_ingestion_items_total[5m]) * 60",
            "legendFormat": "{{stage}} - {{status}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Error Rate by Stage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(dicom_ingestion_items_total{status=\"failed\"}[5m])",
            "legendFormat": "{{stage}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Stage Duration (p99)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(dicom_ingestion_stage_duration_ms_bucket[5m]))",
            "legendFormat": "{{stage}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Stuck Items",
        "type": "stat",
        "targets": [
          {
            "expr": "dicom_ingestion_items_stuck_total",
            "legendFormat": "{{stage}}"
          }
        ],
        "alert": {
          "name": "Stuck Items Alert",
          "condition": {
            "evaluator": {"params": [0], "type": "gt"},
            "reducer": {"type": "last"},
            "query": {"params": ["A", "5m", "now"]}
          },
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "noDataState": "no_data",
          "notifications": [{"uid": "dicom_ingestion_alerts"}]
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 5,
        "title": "Error Breakdown by Type",
        "type": "piechart",
        "targets": [
          {
            "expr": "dicom_ingestion_errors_total",
            "legendFormat": "{{error_code}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16}
      },
      {
        "id": 6,
        "title": "Job Completion Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(dicom_ingestion_jobs_total{status=\"completed\"}[5m])",
            "legendFormat": "completed"
          },
          {
            "expr": "rate(dicom_ingestion_jobs_total{status=\"failed\"}[5m])",
            "legendFormat": "failed"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16}
      },
      {
        "id": 7,
        "title": "Service Health",
        "type": "table",
        "targets": [
          {
            "expr": "up{job=\"dicom-ingestion\"}",
            "format": "table"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16}
      },
      {
        "id": 8,
        "title": "Replay Operations",
        "type": "timeseries",
        "description": "Track replay operations for failure recovery",
        "targets": [
          {
            "expr": "rate(dicom_ingestion_replay_total{status=\"success\"}[5m])",
            "legendFormat": "replay_success"
          },
          {
            "expr": "rate(dicom_ingestion_replay_total{status=\"failed\"}[5m])",
            "legendFormat": "replay_failed"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}
      },
      {
        "id": 9,
        "title": "Conflict Resolution Status",
        "type": "stat",
        "description": "Binding policy conflicts requiring manual intervention",
        "targets": [
          {
            "expr": "dicom_ingestion_conflict_total",
            "legendFormat": "{{resolution_status}}"
          }
        ],
        "alert": {
          "name": "Unresolved Conflicts Alert",
          "condition": {
            "evaluator": {"params": [0], "type": "gt"},
            "reducer": {"type": "last"},
            "query": {"params": ["A", "5m", "now"]}
          },
          "executionErrorState": "alerting",
          "frequency": "5m",
          "handler": 1,
          "noDataState": "no_data",
          "notifications": [{"uid": "dicom_ingestion_alerts"}]
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}
      },
      {
        "id": 10,
        "title": "Indexing Lag",
        "type": "timeseries",
        "description": "Time lag between data persistence and search indexing",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, dicom_ingestion_index_lag_seconds_bucket)",
            "legendFormat": "p99_index_lag"
          },
          {
            "expr": "histogram_quantile(0.95, dicom_ingestion_index_lag_seconds_bucket)",
            "legendFormat": "p95_index_lag"
          }
        ],
        "alert": {
          "name": "High Indexing Lag Alert",
          "condition": {
            "evaluator": {"params": [60], "type": "gt"},
            "reducer": {"type": "last"},
            "query": {"params": ["A", "5m", "now"]}
          },
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "noDataState": "no_data",
          "notifications": [{"uid": "dicom_ingestion_alerts"}]
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}
      },
      {
        "id": 11,
        "title": "Recovery Time (MTTR)",
        "type": "stat",
        "description": "Mean time to recovery for failed items via replay",
        "targets": [
          {
            "expr": "avg(dicom_ingestion_recovery_duration_ms)",
            "legendFormat": "avg_recovery_time"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}
      }
    ]
  }
}
